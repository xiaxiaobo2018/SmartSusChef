<?xml version="1.0" encoding="utf-8"?>
<!--
    Production network security config: cleartext traffic is DENIED by default.
    Only system CA certificates are trusted.
    Flavor-specific configs (local/uat) override this to allow cleartext where needed.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>