@startuml SmartSusChef_Web_AWS_CICD_Pipeline
title SmartSusChef Web/AWS CI/CD Pipeline\n(aws-deploy.yml + pr-validation.yml + test-e2e-perf-dast.yml)

skinparam backgroundColor #FEFEFE
skinparam activity {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  ArrowColor #333333
  DiamondBackgroundColor #FFF9C4
  DiamondBorderColor #F9A825
}
skinparam partition {
  BackgroundColor #F5F5F5
  BorderColor #BDBDBD
}
skinparam note {
  BackgroundColor #FFFDE7
  BorderColor #FBC02D
}

|#E8F5E9| PR Validation (pr-validation.yml) |
start
:Developer pushes code / opens PR;

partition "PR Validation Pipeline\n(Trigger: PR to main / mobile-release)" {
  fork
    :<<Validate Changes>>\nMerge conflict check\nList changed files;
  fork again
    :<<Backend Validation>>\n.NET Restore → Build → Unit Tests;
  fork again
    :<<Frontend Validation>>\nnpm ci → TypeScript check → Build;
  fork again
    :<<ML Validation>>\nRuff auto-fix & commit\nMypy type check\nBandit security scan\nPytest + coverage\nJMeter healthcheck;
  fork again
    :<<Mobile Validation>>\nGradle Build → Unit Tests;
  end fork

  :<<Docker Build Test>>\n(needs Backend + Frontend validation)\nBuild Backend Docker image (test only)\nBuild Frontend Docker image (test only);

  :<<PR Status Comment>>\nPost CI/CD status table to PR;
}

|#E3F2FD| AWS CI/CD Pipeline (aws-deploy.yml) |

partition "STAGE 0: Detect Changes" {
  :<<detect-changes>>\nUse dorny/paths-filter to detect:\n- backend / frontend / ml / mobile / infra\nGenerate version tag;
}

fork
partition "STAGE 1: Security Scanning (DevSecOps)" {
  fork
    :<<CodeQL Security Scan>>\nMatrix: [JS/TS, C#, Python]\nInit → Autobuild → Analyze\nUpload SARIF to GitHub Security\nGenerate HTML report;
  fork again
    :<<Snyk Dependency Scan>>\n.NET scan (backend)\nnpm scan (frontend)\npip scan (ML)\nUpload SARIF per component;
  end fork
}
fork again
partition "STAGE 2: Build & Test (parallel per service)" {
  fork
    :<<Backend Build & Test>>\n.NET Restore → Build\nUnit Tests + Code Coverage\nUpload test results;
  fork again
    :<<Frontend Build & Test>>\nnpm ci → npm audit\nTypeScript check → ESLint\nVitest unit tests + coverage\nnpm run build;
  fork again
    :<<ML Service Build & Test>>\nRuff auto-fix & commit\nRuff lint report\nMypy type check\nBandit security scan\nPytest + coverage\nData validation (placeholder)\nModel validation\nVerify FastAPI imports;
  end fork
}
end fork

partition "STAGE 3: Build & Push Docker Images to ECR" {
  :<<docker-build-push>>\n(needs: detect-changes, backend-build,\nfrontend-build, ml-build)\n__Only on main branch push__;

  :Configure AWS credentials\nLogin to Amazon ECR;

  fork
    :Build & push **Backend** image;
  fork again
    :Build & push **Frontend** image;
  fork again
    :Build & push **ML** image;
  end fork

  note right
    Parallel Docker builds
    Tag: version + latest
  end note

  fork
    :Trivy scan Backend image;
  fork again
    :Trivy scan Frontend image;
  fork again
    :Trivy scan ML image;
  fork again
    :Trivy filesystem scan;
  end fork

  :Upload Trivy SARIF to GitHub Security\nGenerate Trivy HTML report;
}

partition "STAGE 4: Deploy to UAT" {
  :<<deploy-uat>>\n(needs: docker-build-push);

  :Configure AWS credentials\nLoad environment config (RDS endpoint);

  :Prepare ECS task definitions\n(envsubst: backend, frontend, ml);

  :Render task definitions\nwith new Docker image URIs;

  fork
    :Deploy **Backend** to ECS;
  fork again
    :Deploy **Frontend** to ECS;
  fork again
    :Deploy **ML** to ECS;
  end fork

  :Wait for all services stable\n(up to 15 min);

  :Ensure ALB routes /swagger → backend;

  :Run UAT Smoke Tests\n(Frontend / Backend / Swagger);
}

fork
partition "STAGE 4b: E2E Tests" {
  :<<Playwright E2E Tests>>\nInstall Playwright\nRun against UAT ALB URL\nUpload report;
}
fork again
partition "STAGE 4c: Performance Tests" {
  :<<JMeter Performance Tests>>\nRun load test against UAT\nCalculate Apdex score\n(threshold 500ms, target ≥ 0.85)\nUpload JTL + HTML report;
}
fork again
partition "STAGE 4d: DAST Security Scan" {
  :<<OWASP ZAP DAST Scan>>\nLogin → get JWT token;

  fork
    :ZAP Baseline Scan (Frontend);
  fork again
    :ZAP API Scan (Backend)\nAuthenticated via auth-hook.py\nOpenAPI spec based;
  end fork

  :Verify API controller coverage\n(12 controllers)\nAlert summary (High/Med/Low/Info)\nUpload reports;
}
end fork

partition "STAGE 5: Deploy to Production" {
  :<<deploy-production>>\n(needs: UAT deploy, E2E, JMeter, DAST)\n__Requires GitHub Environment approval__;

  :Configure AWS credentials\nPrepare production task definitions;

  fork
    :Deploy **Backend** to Prod ECS;
  fork again
    :Deploy **Frontend** to Prod ECS;
  fork again
    :Deploy **ML** to Prod ECS;
  end fork

  :Wait for all services stable;

  :Ensure ALB /swagger route\nRun Production Smoke Tests;
}

partition "STAGE 6: Pipeline Summary" {
  :<<notify>>\nGenerate CI/CD summary table\n(all stage results);
}

|#FFF3E0| Manual Tests (test-e2e-perf-dast.yml) |

partition "Manual Trigger Pipeline\n(workflow_dispatch with inputs)" {
  note right
    Inputs:
    - run_e2e (bool)
    - run_jmeter (bool)
    - run_dast (bool)
    - target_url (string)
    - db_environment (uat/production)
  end note

  fork
    :<<E2E Tests (Playwright)>>\nRun against custom target URL;
  fork again
    :<<JMeter Performance Tests>>\nClean test data via API\nRun Main_Scenario.jmx\nApdex score calculation;
  fork again
    :<<DAST (OWASP ZAP)>>\nAuthenticated API scan\nBaseline frontend scan;
  end fork

  :<<Test Summary>>\nConsolidate all results;
}

stop

legend right
  |= Color |= Meaning |
  |<#E8F5E9>| PR Validation Pipeline |
  |<#E3F2FD>| AWS CI/CD Pipeline (main) |
  |<#FFF3E0>| Manual Test Pipeline |
  |<#FFF9C4>| Decision / Condition |
endlegend

@enduml
