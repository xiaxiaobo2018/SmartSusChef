@startuml SmartSusChef_DevSecOps_Toolchain

title SmartSusChef - DevSecOps Toolchain Architecture
caption Shift-Left Security | Automated CI/CD | Multi-Service Deployment

top to bottom direction

skinparam backgroundColor #FEFEFE
skinparam defaultFontName "Segoe UI"
skinparam shadowing false
skinparam roundCorner 8
skinparam rectangleBorderThickness 1.5
skinparam nodesep 30
skinparam ranksep 40

skinparam rectangle {
    BackgroundColor<<dev>> #E8F5E9
    BorderColor<<dev>> #4CAF50
    BackgroundColor<<sec>> #FFEBEE
    BorderColor<<sec>> #E53935
    BackgroundColor<<build>> #E3F2FD
    BorderColor<<build>> #1E88E5
    BackgroundColor<<container>> #EDE7F6
    BorderColor<<container>> #5E35B1
    BackgroundColor<<deploy>> #F3E5F5
    BorderColor<<deploy>> #8E24AA
    BackgroundColor<<monitor>> #FFF8E1
    BorderColor<<monitor>> #F9A825
    BackgroundColor<<infra>> #E0F7FA
    BorderColor<<infra>> #00838F
}

skinparam component {
    FontSize 11
}

' ================================================================
'  ROW 1: DEVELOPMENT PHASE
' ================================================================
rectangle "PLAN & CODE" as r_dev <<dev>> {
    actor "Developer" as dev
    component "VS Code" as vscode
    component "GitHub Repository" as github {
        component "main branch" as main
        component "Pull Requests" as pr
    }
    component "Local Dev\n(dev-start.ps1/.sh)" as localdev {
        component ".NET 8 API :5000" as local_be
        component "React+Vite :5173" as local_fe
        component "FastAPI ML :8000" as local_ml
    }
}

' ================================================================
'  ROW 2: CHANGE DETECTION
' ================================================================
rectangle "CHANGE DETECTION" as r_detect <<build>> {
    component "dorny/paths-filter" as pathfilter
    component "backend/**" as pf_be
    component "frontend/**" as pf_fe
    component "ML/**" as pf_ml
    component "mobile/**" as pf_mob
    note bottom of pathfilter
        Selective pipeline:
        only changed services
        are built & deployed.
    end note
}

' ================================================================
'  ROW 3: SECURITY + BUILD (side by side)
' ================================================================
rectangle "SECURITY SCANNING\n(Shift-Left)" as r_sec <<sec>> {
    component "CodeQL SAST" as codeql {
        component "C# / TS / Python\nJava/Kotlin" as cql_all
    }
    component "Trivy FS Scan\n(SARIF)" as trivy_fs {
        component "Dependency CVEs\n+ Secret Detection" as trivy_dep
    }
    component "GitHub Security\nDashboard" as sec_dash
}

rectangle "BUILD & TEST\n(Parallel)" as r_build <<build>> {
    component "Backend (.NET 8)" as build_be {
        component "restore → build\n→ test (xUnit)" as be_steps
    }
    component "Frontend (Node 20)" as build_fe {
        component "npm ci\n→ Vite build" as fe_steps
    }
    component "ML (Python 3.11)" as build_ml {
        component "pip install\n→ pytest" as ml_steps
    }
    component "Mobile (Kotlin)" as build_mob {
        component "Gradle build\n→ test" as mob_steps
    }
}

' ================================================================
'  ROW 4: CONTAINER BUILD & SCAN
' ================================================================
rectangle "CONTAINER BUILD & SCAN" as r_container <<container>> {
    component "Docker Buildx" as buildx
    component "Amazon ECR" as ecr {
        component "backend :latest" as ecr_be
        component "frontend :latest" as ecr_fe
        component "ml-api :latest" as ecr_ml
    }
    component "Trivy Image Scan" as trivy_img {
        component "OS CVE + Lib CVE\n(CRITICAL, HIGH)" as trivy_scan
    }
}

' ================================================================
'  ROW 5: DEPLOYMENT
' ================================================================
rectangle "DEPLOYMENT (Parallel ECS)" as r_deploy <<deploy>> {
    rectangle "UAT Environment" as uat {
        component "ECS Fargate\n(smartsuschef-uat)" as uat_ecs {
            component "BE :8080 | FE :80\nML :8000" as uat_svc
        }
        component "RDS MySQL 8.0\n(uat-db)" as uat_db
        component "Smoke Tests\n(curl health)" as uat_smoke
    }
    rectangle "Production" as prod {
        component "ECS Fargate\n(smartsuschef-prod)" as prod_ecs {
            component "BE | FE | ML" as prod_svc
        }
        component "RDS MySQL 8.0\n(prod-db)" as prod_db
        component "ALB + HTTPS\n(TLS 1.3)" as prod_alb
    }
    component "GitHub Env Secrets" as gh_secrets {
        component "DB_PASSWORD\nJWT_SECRET\nAWS Creds" as sec_items
    }
}

' ================================================================
'  ROW 6: INFRA + MONITORING (side by side)
' ================================================================
rectangle "INFRASTRUCTURE AS CODE" as r_infra <<infra>> {
    component "Terraform" as terraform {
        component "VPC + Subnets" as tf_vpc
        component "ECS + Fargate" as tf_ecs
        component "ALB (HTTP→HTTPS)" as tf_alb
        component "RDS + SG" as tf_rds
        component "ECR + Cloud Map" as tf_ecr
    }
}

rectangle "MONITORING &\nOBSERVABILITY" as r_monitor <<monitor>> {
    component "AWS CloudWatch" as cw {
        component "Logs + Metrics\n(CPU/Memory)" as cw_all
    }
    component "Health Endpoints" as health {
        component "/health (BE/ML/FE)" as h_all
    }
    component "ALB Health Checks\n(30s interval)" as alb_health
    component "GitHub Actions\nPipeline Summary" as gh_summary
}

' ================================================================
'  VERTICAL FLOW (force top-to-bottom stacking)
' ================================================================
r_dev -[hidden]down- r_detect
r_detect -[hidden]down- r_sec
r_detect -[hidden]down- r_build
r_sec -[hidden]down- r_container
r_build -[hidden]down- r_container
r_container -[hidden]down- r_deploy
r_deploy -[hidden]down- r_infra
r_deploy -[hidden]down- r_monitor

' ================================================================
'  FLOW CONNECTIONS
' ================================================================

' Dev flow
dev -down-> vscode
vscode -down-> github : git push
github -right-> localdev : dev-start scripts

' Trigger
main -down-> pathfilter : push / PR\nGitHub Actions

' Security (parallel with build)
pathfilter -down-> codeql : All languages\n(4 parallel)
pathfilter -down-> trivy_fs : FS scan
codeql -down-> sec_dash : SARIF
trivy_fs -down-> sec_dash : SARIF

' Build (parallel, selective)
pathfilter -down-> build_be : backend changed
pathfilter -down-> build_fe : frontend changed
pathfilter -down-> build_ml : ML changed
pathfilter -down-> build_mob : mobile changed

' Container
build_be -down-> buildx
build_fe -down-> buildx
build_ml -down-> buildx
buildx -down-> ecr : Push images
ecr -down-> trivy_img : Scan images\n(exit-code: 1)

' Deploy
trivy_img -down-> uat_ecs : Parallel deploy\n(3 services)
gh_secrets -right-> uat_ecs : Inject secrets
uat_ecs -down-> uat_db
uat_smoke -right-> prod_ecs : After UAT passes
gh_secrets -right-> prod_ecs
prod_ecs -down-> prod_db
prod_alb -right-> prod_ecs : Route traffic

' Monitoring
prod_ecs -down-> cw : Stream logs
prod_ecs -down-> health : Expose endpoints
prod_alb -down-> alb_health : Check targets
cw -down-> gh_summary

' IaC
terraform .down.> uat : Provision
terraform .down.> prod : Provision

' ================================================================
'  LEGEND
' ================================================================
legend bottom
  |= Color |= Phase |
  | <#E8F5E9> | Plan & Code |
  | <#FFEBEE> | Security Scanning |
  | <#E3F2FD> | Build & Test |
  | <#EDE7F6> | Container & Image Scan |
  | <#F3E5F5> | Deployment |
  | <#E0F7FA> | Infrastructure as Code |
  | <#FFF8E1> | Monitoring |

  **Key DevSecOps Practices:**
  * Shift-left: CodeQL SAST on every push
  * Supply chain: Trivy filesystem + image scans
  * Secrets: GitHub Environment Secrets (not in code)
  * HTTPS enforced: TLS 1.3, HTTP->HTTPS redirect
  * Least privilege: ECS SG port-restricted
  * Selective CI: path-based change detection
  * Parallel deploy: 3 ECS services simultaneously
end legend

@enduml
